# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
# ----------------------------------------------------------------------
# IMPORTANT FOR CONTRIBUTORS: 
# To connect to the shared development database, please request the 
# MONGODB_URI credentials from the project maintainer via the Git issue, 
# OR set up your own local MongoDB instance for testing.
# ----------------------------------------------------------------------

# Example Local URI:
# MONGODB_URI=mongodb://localhost:27017/stellarproof

# Example Cloud URI (MongoDB Atlas):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/stellarproof?retryWrites=true&w=majority

# JWT Configuration
# ----------------------------------------------------------------------
# IMPORTANT FOR CONTRIBUTORS:
# Generate a strong secret for production (e.g., openssl rand -hex 64)
# ----------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Cloudinary Configuration (SPV encrypted asset storage)
# ----------------------------------------------------------------------
# IMPORTANT FOR CONTRIBUTORS:
# Request Cloudinary credentials from the project maintainer, or create
# a free account at https://cloudinary.com and use your own cloud.
# ----------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# KMS Master Key (encrypts symmetric keys before DB storage)
# ----------------------------------------------------------------------
# IMPORTANT FOR CONTRIBUTORS:
# Must be exactly 64 hex characters (32 bytes for AES-256).
# Generate with: openssl rand -hex 32
# ----------------------------------------------------------------------
KMS_MASTER_KEY=your_64_char_hex_master_key_here

# Pinata IPFS Configuration (SPV encrypted asset pinning)
# ----------------------------------------------------------------------
# IMPORTANT FOR CONTRIBUTORS:
# Request Pinata credentials from the project maintainer, or create a
# free account at https://pinata.cloud and generate a JWT API key.
# ----------------------------------------------------------------------
PINATA_JWT=your_pinata_jwt_token_here
